{
  "name": "sgdb-service-desk",
  "version": "1.0.0",
  "private": true,
  "description": "API Service Desk + Ativos (PostgreSQL)",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
    "check-db": "node scripts/check-db.js",
    "docker:up": "docker compose up -d db",
    "docker:bootstrap": "powershell -ExecutionPolicy Bypass -File scripts/bootstrap-docker.ps1",
    "docker:bootstrap:sh": "bash scripts/bootstrap-docker.sh"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0"
  }
}
